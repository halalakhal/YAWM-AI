# ── LLM ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── Google Calendar ─────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_PATH=./config/google_credentials.json
GOOGLE_TOKEN_PATH=./config/google_token.json


YOUTUBE_API_KEY=
GMAIL_APP_PASSWORD=

GMAIL_SENDER_EMAIL=
GMAIL_RECIPIENT_EMAIL=
NOTIFY_CHANNEL=gmail
# ── Notion ──────────────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Todoist ─────────────────────────────────────────────────────────
TODOIST_API_TOKEN=

# ── Canva ───────────────────────────────────────────────────────────
# (We use Pillow locally — no Canva key needed unless using Canva API)
CANVA_API_TOKEN=

# ── Prayer Times — AlAdhan (free, no key) ───────────────────────────
ALADHAN_API_URL=https://api.aladhan.com/v1
PRAYER_CITY=Casablanca
PRAYER_COUNTRY=Morocco
PRAYER_METHOD=2

# ── App ─────────────────────────────────────────────────────────────
USER_TIMEZONE=Africa/Casablanca
RAMADAN_DAY=21
OUTPUT_DIR=./output
LOG_LEVEL=INFO

# ── Canva MCP ────────────────────────────────────────────────────────────────
CANVA_MCP_MODE=
CANVA_CLIENT_ID=      # from Canva Developer portal
CANVA_CLIENT_SECRET=  # from Canva Developer portal
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=
CANVA_BRAND_TEMPLATE_ID=               # optional, paste your template ID if you have one

# ── Canva API ────────────────────────────────────────────────────────────────
CANVA_API_TOKEN=
# Agent 8 will autofill it with your schedule data instead of creating blank
CANVA_BRAND_TEMPLATE_ID=

LANGFUSE_SECRET_KEY=
